# ScrambleCoin StarterBot — environment variables
# Copy this file to .env and fill in the values.
# Then load it before running: `export $(cat .env | xargs) && dotnet run`

# Base URL of the ScrambleCoin API server (no trailing slash)
BASE_URL=http://localhost:5000

# Display name for this bot (used in console output only)
BOT_NAME=MyBot

# (Optional) Join a specific pre-created game instead of using matchmaking.
# Leave blank or unset to use the matchmaking queue.
# GAME_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
